# OneView Hospitality Platform — Environment Variables
# Copy this file to .env and adjust values

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=oneview
POSTGRES_USER=oneview_user
POSTGRES_PASSWORD=oneview_secret_2024

# ─── Service Ports ────────────────────────────────────────────
GATEWAY_PORT=8000
HOTEL_PORT=8001
RESTAURANT_PORT=8002
REALESTATE_PORT=8003
ANALYTICS_PORT=8004
CHATBOT_PORT=8005
DASHBOARD_PORT=3000

# ─── JWT Auth (gateway) ───────────────────────────────────────
JWT_SECRET=change_me_in_production_supersecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Analytics / AI ───────────────────────────────────────────
MODELS_PATH=/app/models
FORECAST_HORIZON_DAYS=14

# ─── Anthropic API (chatbot — optional) ───────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Data Generation ──────────────────────────────────────────
DATA_START_DATE=2023-01-01
DATA_END_DATE=2024-12-31
RANDOM_SEED=42
