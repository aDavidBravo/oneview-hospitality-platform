# OneView Hospitality Platform - Environment Variables
# Copy this file to .env and adjust values

# ==========================================
# DATABASE
# ==========================================
POSTGRES_USER=oneview
POSTGRES_PASSWORD=oneview_secure_2024
POSTGRES_DB=oneview_db
DATABASE_URL=postgresql://oneview:oneview_secure_2024@postgres:5432/oneview_db

# ==========================================
# SECURITY
# ==========================================
JWT_SECRET=change_this_to_a_random_secret_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==========================================
# SERVICE PORTS
# ==========================================
GATEWAY_PORT=8000
HOTEL_SERVICE_PORT=8001
RESTAURANT_SERVICE_PORT=8002
REALESTATE_SERVICE_PORT=8003
ANALYTICS_SERVICE_PORT=8004
CHATBOT_SERVICE_PORT=8005
DASHBOARD_PORT=3000

# ==========================================
# CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==========================================
# ML SETTINGS
# ==========================================
MODEL_PATH=/app/models
FORECAST_HORIZON_DAYS=14

# ==========================================
# DATA GENERATION
# ==========================================
DATA_START_DATE=2023-01-01
DATA_END_DATE=2024-12-31
RANDOM_SEED=42
